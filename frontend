// Handle Login/Signup
document.addEventListener('DOMContentLoaded', function() {
const loginForm = document.getElementById('loginForm');
const signupForm = document.getElementById('signupForm');

if (loginForm) {
loginForm.addEventListener('submit', function(e) {
e.preventDefault();

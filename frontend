<header>
<nav class="container">
<div class="logo">🎬 CinemaMax</div>
<div class="nav-links">
<a onclick="showPage('home')">Movies</a>
<a onclick="showPage('events')">Events</a>
<a onclick="showPage('sports')">Sports</a>
<a>Location</a>

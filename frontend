// Date selection
function selectDate(dateBtn) {
document.querySelectorAll('.date-btn').forEach(btn => btn.classList.remove('active'));
dateBtn.classList.add('active');
}

// Select Theater and Show
function selectTheaterShow(theater, time) {
currentTheater = theater;
currentTime = time;

document.getElementById('selectedTheater').textContent = theater;
document.getElementById('selectedShowtime').textContent = 'Today, ' + time;
document.getElementById('selectedMovie').textContent = currentMovie;

showPage('seatSelection');
}

// Seat Selection
function toggleSeat(seat) {
if (seat.classList.contains('booked')) return;

seat.classList.toggle('selected');
updateSelectedSeats();
}

function updateSelectedSeats() {
const seats = document.querySelectorAll('.seat.selected');
selectedSeats = Array.from(seats).map(seat => seat.dataset.seat);

document.getElementById('selectedSeats').textContent = selectedSeats.length ? selectedSeats.join(', ') : 'None';
document.getElementById('totalPrice').textContent = selectedSeats.length * seatPrice;

// Also update payment page when seats are selected
updatePaymentSummary();
}

// Update payment summary
function updatePaymentSummary() {
const ticketTotal = selectedSeats.length * seatPrice;
document.getElementById('ticketPrice').textContent = ticketTotal;
updateGrandTotal();
}

// Add-on quantity management
function changeQty(item, change) {
addOns[item].qty = Math.max(0, addOns[item].qty + change);
document.getElementById(item + 'Qty').textContent = addOns[item].qty;
updateGrandTotal();
}

function updateGrandTotal() {
let total = selectedSeats.length * seatPrice;
total += addOns.popcorn.price * addOns.popcorn.qty;
total += addOns.nachos.price * addOns.nachos.qty;

document.getElementById('grandTotal').textContent = total;
const payButtonElement = document.getElementById('payButton');
if (payButtonElement) {
payButtonElement.textContent = total;
}
}

// Payment method selection
function selectPaymentMethod(method) {
document.querySelectorAll('.payment-option').forEach(option => {
option.classList.remove('active');
});
event.currentTarget.classList.add('active');

// Hide all forms
document.querySelectorAll('.payment-form').forEach(form => {
form.style.display = 'none';
});

// Show selected form
document.getElementById(method + 'Form').style.display = 'block';

// Update QR code amount for UPI
if (method === 'upi') {
const total = document.getElementById('grandTotal').textContent;
const qrImg = document.querySelector('#upiForm .qr-code-image img');
if (qrImg) {
qrImg.src = `https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=upi://pay?pa=cinemamaxpay@upi&pn=CinemaMax&am=${total}&cu=INR`;
}
}
}

// Payment Processing
function processPayment() {
if (selectedSeats.length === 0) {
alert('Please select seats first!');
return;
}

// Update payment summary
document.getElementById('paymentMovie').textContent = currentMovie;
document.getElementById('paymentTheater').textContent = currentTheater;
document.getElementById('paymentDateTime').textContent = 'Today, ' + currentTime;
document.getElementById('paymentSeats').textContent = selectedSeats.join(', ');
updatePaymentSummary();

// Update confirmation page
document.getElementById('confirmMovie').textContent = currentMovie;
document.getElementById('confirmTheater').textContent = currentTheater;
document.getElementById('confirmDateTime').textContent = 'Today, ' + currentTime;
document.getElementById('confirmSeats').textContent = selectedSeats.join(', ');
document.getElementById('confirmTotal').textContent = document.getElementById('grandTotal').textContent;

alert('Payment successful!');
showPage('confirmation');
}

// Movie filtering functionality
function filterMovies(category) {
// Update active button
document.querySelectorAll('.category-btn').forEach(btn => {
btn.classList.remove('active');
});
event.target.classList.add('active');

// Show/hide movie sections based on category
const sections = {
'all': ['now-showing-section', 'coming-soon-section', 'streaming-section'],
'now-showing': ['now-showing-section'],
'coming-soon': ['coming-soon-section'],
'streaming': ['streaming-section'],
'imax': ['now-showing-section', 'coming-soon-section']
};

// Hide all sections first
document.querySelectorAll('.movie-section').forEach(section => {
section.style.display = 'none';
});

// Show relevant sections
if (sections[category]) {
sections[category].forEach(sectionId => {
const section = document.getElementById(sectionId);
if (section) section.style.display = 'block';
});
}

// Special handling for IMAX filter
if (category === 'imax') {
document.querySelectorAll('.movie-card').forEach(card => {
if (card.classList.contains('imax')) {
card.style.display = 'block';
} else {
card.style.display = 'none';
}
});
} else if (category !== 'all') {
// For specific categories, show only matching cards
document.querySelectorAll('.movie-card').forEach(card => {
if (card.classList.contains(category)) {
card.style.display = 'block';
} else {
card.style.display = 'none';
}
});
} else {
// Reset all movie cards visibility for 'all' category
document.querySelectorAll('.movie-card').forEach(card => {
card.style.display = 'block';
});
}
}

// Search functionality
function searchMovies() {
const searchTerm = document.querySelector('.search-input').value.toLowerCase();
document.querySelectorAll('.movie-card').forEach(card => {
const title = card.querySelector('.movie-title').textContent.toLowerCase();
const genre = card.querySelector('.movie-genre').textContent.toLowerCase();

if (title.includes(searchTerm) || genre.includes(searchTerm) || searchTerm === '') {
card.style.display = 'block';
} else {
card.style.display = 'none';
}
});
}
</script>
</body>
